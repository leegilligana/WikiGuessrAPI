root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
#### Severity Levels ####
# Standardizes warnings so they break the build if EnforceCodeStyleInBuild is true
dotnet_analyzer_diagnostic.category-Style.severity = warning
dotnet_analyzer_diagnostic.category-Naming.severity = warning

#### Modern C# Preferences ####
csharp_style_namespace_declarations = file_scoped:error
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion
csharp_style_prefer_primary_constructors = true:suggestion

#### Naming Conventions ####
dotnet_naming_rule.interface_should_be_begun_with_i.severity = error
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = any_interface
dotnet_naming_rule.interface_should_be_begun_with_i.style = begun_with_i

dotnet_naming_symbols.any_interface.applicable_kinds = interface
dotnet_naming_style.begun_with_i.required_prefix = I

#### Redundancy & Cleanup ####
dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_qualification_for_event = false:error
dotnet_style_require_accessibility_modifiers = always:error
csharp_style_unused_value_expression_statement_preference = discard:suggestion

#### StyleCop-Equivalent "Strict" Rules (Built-in) ####
dotnet_diagnostic.SA1200.severity = none
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.IDE0005.severity = warning
dotnet_diagnostic.IDE0008.severity = none
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA1515.severity = none
